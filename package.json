{
  "name": "geo-rs",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @geo-rs/site dev",
    "build": "pnpm --filter @geo-rs/core build && pnpm --filter @geo-rs/vue build",
    "typecheck": "pnpm --filter @geo-rs/core build && pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "devDependencies": {
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.59.3"
  }
}
