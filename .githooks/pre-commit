#!/bin/sh
# Pre-commit checks
set -e

echo "[pre-commit] Checking Rust formatting..."
cargo fmt --all -- --check

echo "[pre-commit] Running Clippy..."
cargo clippy --workspace --exclude geo-wasm -- -D warnings 2>/dev/null || true

echo "[pre-commit] Running tests..."
cargo test --workspace --exclude geo-wasm -q 2>/dev/null
cargo test -p geo-wasm -q 2>/dev/null

echo "[pre-commit] TypeScript typecheck..."
pnpm typecheck 2>/dev/null || true

echo "[pre-commit] OK"
